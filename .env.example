# Repository-Root .env — wird von docker-compose fuer ${VAR}-Substitutionen
# in docker-compose.yml geladen. Werte hier ueberschreiben environment-
# Defaults im compose-File und werden in den jeweiligen Container injiziert.
#
# Anwendungs-Konfiguration (DB-Credentials, API-Keys etc.) gehoert in
# backend/.env (siehe backend/.env.example).

# ── Sentry Error-Tracking ────────────────────────────────────────────────
#
# Account-Einrichtung:
#   1. Account auf sentry.io anlegen (Free-Tier reicht: 5k Events/Monat)
#   2. Beim Signup EU-Region waehlen (Server in Frankfurt, DSGVO-konform)
#   3. Neues Projekt anlegen -> Platform "Python / FastAPI"
#   4. Settings -> Client Keys (DSN) -> den DSN-String kopieren
#
# Wichtig: der DSN muss "ingest.de.sentry.io" enthalten (EU-Region).
# Wenn dort "ingest.sentry.io" (ohne de) steht, wurde US-Region gewaehlt —
# dann Projekt neu anlegen, US-DSN nicht nutzen (Daten liegen in den USA).
#
# Nach dem ersten Deploy mit gesetztem DSN den Endpoint
# POST /api/_admin/sentry-test (mit X-Admin-Token Header) einmal aufrufen.
# Ein RuntimeError landet in Sentry; wenn dort die Mailadresse als
# [email]@example.test erscheint, ist auch der PII-Scrubber aktiv.
#
# Verifikation auf dem Server, dass docker-compose den DSN sieht:
#   docker compose config | grep SENTRY_DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Raster-Volume-Mount ──────────────────────────────────────────────────
# Host-Pfad fuer das /app/rasters Volume im Backend-Container. Default ist
# ./rasters im Repo-Root. Auf dem Server typisch /opt/bodenbericht/rasters.
RASTER_DIR=./rasters
