{#
  SEO-Long-Tail-Stadt-Page · 2026-05-05
  Wird von build_seo_pages.py mit Daten aus seo_pages.json gerendert
  -> Output: landing/orte/<thema>-<stadt_slug>.html

  Struktur folgt landing/wissen/insar-egms.html (DefinedTerm + FAQPage)
  damit Google das gleiche Trust-Signal bekommt.
#}
<!DOCTYPE html>
<html lang="{{ lang | default('de') }}">
<head>

<script defer src="/klaro/klaro-config.js"></script>
<script defer src="/klaro/klaro.js"></script>

<script type="text/plain" data-type="application/javascript" data-name="google-tag-manager">
(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-KFG5W96X');
</script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ seo_title }}</title>
    <meta name="description" content="{{ meta_description }}">
    <link rel="canonical" href="https://bodenbericht.de/orte/{{ thema_slug }}-{{ stadt_slug }}.html">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/favicon.svg">
    <meta property="og:type" content="article">
    <meta property="og:site_name" content="Bodenbericht">
    <meta property="og:url" content="https://bodenbericht.de/orte/{{ thema_slug }}-{{ stadt_slug }}.html">
    <meta property="og:title" content="{{ og_title | default(seo_title) }}">
    <meta property="og:description" content="{{ og_description | default(meta_description) }}">
    <meta property="og:image" content="https://bodenbericht.de/og-image.png">
    <meta property="og:locale" content="{{ og_locale | default('de_DE') }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ og_title | default(seo_title) }}">
    <meta name="twitter:description" content="{{ og_description | default(meta_description) }}">
    <meta name="twitter:image" content="https://bodenbericht.de/og-image.png">
    <link rel="stylesheet" href="/tailwind.css">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            {"@type": "ListItem", "position": 1, "name": "Bodenbericht", "item": "https://bodenbericht.de/"},
            {"@type": "ListItem", "position": 2, "name": "Orte", "item": "https://bodenbericht.de/orte/"},
            {"@type": "ListItem", "position": 3, "name": {{ stadt_name | tojson }}, "item": "https://bodenbericht.de/orte/{{ thema_slug }}-{{ stadt_slug }}.html"}
          ]
        },
        {
          "@type": "WebPage",
          "@id": "https://bodenbericht.de/orte/{{ thema_slug }}-{{ stadt_slug }}.html#webpage",
          "url": "https://bodenbericht.de/orte/{{ thema_slug }}-{{ stadt_slug }}.html",
          "name": {{ seo_title | tojson }},
          "description": {{ meta_description | tojson }},
          "inLanguage": "{{ inLanguage | default('de-DE') }}",
          "isPartOf": {"@type": "WebSite", "name": "Bodenbericht", "url": "https://bodenbericht.de/"},
          "about": {
            "@type": "Place",
            "name": {{ stadt_name | tojson }},
            "geo": {
              "@type": "GeoCoordinates",
              "latitude": {{ lat }},
              "longitude": {{ lon }}
            }
          }
        }
        {%- if faq_items %},
        {
          "@type": "FAQPage",
          "@id": "https://bodenbericht.de/orte/{{ thema_slug }}-{{ stadt_slug }}.html#faq",
          "mainEntity": [
            {%- for item in faq_items %}
            {
              "@type": "Question",
              "name": {{ item.frage | tojson }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ item.antwort | tojson }}
              }
            }{% if not loop.last %},{% endif %}
            {%- endfor %}
          ]
        }
        {%- endif %}
      ]
    }
    </script>

    <style>
        html { scroll-behavior: smooth; }
        .hero-gradient { background: linear-gradient(135deg, #0c1d3a 0%, #122b52 40%, #1a3a6b 100%); }
    </style>
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/inter-600.woff2" as="font" type="font/woff2" crossorigin>

</head>
<body class="font-sans text-gray-800 antialiased">

    <header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-100 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16 md:h-18">
                <a href="/index.html" class="flex items-center gap-2" aria-label="Bodenbericht Startseite">
                    <img src="/images/logo-horizontal.png" alt="Bodenbericht - digitale Bodenbewertung und Analyse" class="h-10 md:h-12 w-auto" width="640" height="214" loading="eager" decoding="async">
                </a>
                <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
                    <a href="/index.html#so-funktionierts" class="hover:text-navy-700 transition">So funktioniert's</a>
                    <a href="/index.html#leistungen" class="hover:text-navy-700 transition">Leistungen</a>
                    <a href="/datenquellen.html" class="hover:text-navy-700 transition">Datenquellen</a>
                    <a href="/index.html#faq" class="hover:text-navy-700 transition">FAQ</a>
                </nav>
                <a href="/index.html#cta" class="hidden sm:inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition shadow-md shadow-brand-600/20">
                    Bericht anfordern
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </a>
            </div>
        </div>
    </header>

    <section class="hero-gradient pt-28 pb-16 md:pt-32 md:pb-20 relative overflow-hidden">
        <div class="absolute inset-0 opacity-5">
            <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
        </div>
        <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <nav class="text-xs text-white/60 mb-6" aria-label="Breadcrumb">
                <a href="/" class="hover:text-white transition">Bodenbericht</a>
                <span class="mx-2">›</span>
                <a href="/orte/" class="hover:text-white transition">Orte</a>
                <span class="mx-2">›</span>
                <span class="text-white/80">{{ stadt_name }} · {{ thema_label }}</span>
            </nav>
            <p class="text-brand-300 font-semibold text-xs tracking-wide uppercase mb-3">{{ eyebrow | default('Standortauskunft') }}</p>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight tracking-tight">
                {{ h1 }}
            </h1>
            <p class="mt-6 text-lg md:text-xl text-gray-300 leading-relaxed">
                {{ hero_intro }}
            </p>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

            {%- for section in content_sections %}
            <h2 class="text-2xl md:text-3xl font-extrabold text-navy-800 tracking-tight {% if not loop.first %}mt-10{% else %}mt-2{% endif %}">{{ section.heading }}</h2>
            {%- for paragraph in section.paragraphs %}
            <p class="text-gray-700 leading-relaxed {% if loop.first %}mt-4{% else %}mt-3{% endif %}">{{ paragraph | safe }}</p>
            {%- endfor %}
            {%- endfor %}

            {%- if related_links %}
            <aside class="bg-gray-50 border border-gray-200 rounded-2xl p-6 my-12">
                <p class="text-xs uppercase tracking-wide font-bold text-brand-700 mb-3">Verwandte Begriffe und Kontexte</p>
                <div class="flex flex-wrap gap-2">
                    {%- for link in related_links %}
                    <a href="{{ link.href }}" class="inline-block px-3 py-1.5 rounded-full bg-white border border-gray-200 text-xs font-medium text-gray-700 hover:bg-brand-50 hover:border-brand-200 hover:text-brand-700 transition">{{ link.label }}</a>
                    {%- endfor %}
                </div>
            </aside>
            {%- endif %}
        </div>
    </section>

    {%- if faq_items %}
    <section class="py-12 md:py-16 bg-gray-50 border-y border-gray-100">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <p class="text-brand-600 font-semibold text-sm tracking-wide uppercase mb-3">Häufige Fragen</p>
            <h2 class="text-2xl md:text-3xl font-extrabold text-navy-800 tracking-tight mb-8">Was Käufer in {{ stadt_name }} am häufigsten fragen.</h2>
            <div class="space-y-3">
                {%- for item in faq_items %}
                <details class="border border-gray-200 rounded-xl overflow-hidden group bg-white">
                    <summary class="cursor-pointer w-full flex items-center justify-between px-6 py-5 hover:bg-gray-50 transition list-none">
                        <span class="font-semibold text-navy-800 text-sm md:text-base pr-4">{{ item.frage }}</span>
                        <svg class="w-5 h-5 text-gray-500 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                    </summary>
                    <div class="px-6 pb-5">
                        <p class="text-gray-600 text-sm leading-relaxed">{{ item.antwort | safe }}</p>
                    </div>
                </details>
                {%- endfor %}
            </div>
        </div>
    </section>
    {%- endif %}

    <section class="py-12 bg-white border-t border-gray-100">
        <div class="max-w-2xl mx-auto px-4 text-center">
            <p class="text-gray-600">{{ cta_lead | default('Haben Sie eine konkrete Adresse in ' ~ stadt_name ~ '?') }}</p>
            <a href="/index.html#cta" class="mt-5 inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-6 py-3 rounded-lg transition shadow-md shadow-brand-600/20">
                Bericht für Ihre Adresse anfordern
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
        </div>
    </section>

    <aside class="bg-gray-50 border-t border-gray-200 py-6">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-xs text-gray-600 leading-relaxed">
            <p>
                <strong class="text-navy-800">Hinweis:</strong> Der Bodenbericht ist ein automatisiertes Datenscreening auf Basis &ouml;ffentlich verf&uuml;gbarer EU- und Bundesdaten. Er ersetzt weder eine Vor-Ort-Begutachtung, noch eine Laboranalyse, noch ein Sachverst&auml;ndigengutachten nach &sect;18 BBodSchG. Datenquellen, Lizenzen und Methodik: <a href="/datenquellen.html" class="text-brand-700 underline hover:text-brand-800">datenquellen.html</a>.
            </p>
        </div>
    </aside>

    <footer class="bg-navy-900 text-gray-300 py-12 md:py-16 border-t border-navy-700">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-5 gap-8 mb-10">
                <div class="md:col-span-2">
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center">
                            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                        </div>
                        <span class="text-lg font-bold text-white tracking-tight">Boden<span class="text-brand-400">bericht</span></span>
                    </div>
                    <p class="text-sm leading-relaxed max-w-sm">
                        Adress-basiertes Bodenrisiko-Screening für Privatpersonen, Landwirte und Immobilienkäufer. Auf Basis offizieller EU-Datensätze. Einfach, schnell und zuverlässig.
                    </p>
                </div>
                <div>
                    <h4 class="font-semibold text-white text-sm mb-4">Für wen</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/fuer-immobilienkaeufer.html" class="hover:text-white transition">Für Käufer</a></li>
                        <li><a href="/fuer-gartenbesitzer.html" class="hover:text-white transition">Für Gartenbesitzer</a></li>
                        <li><a href="/fuer-bautraeger.html" class="hover:text-white transition">Für Bauträger</a></li>
                        <li><a href="/fuer-landwirte.html" class="hover:text-white transition">Für Landwirte</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-semibold text-white text-sm mb-4">Service</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/datenquellen.html" class="hover:text-white transition">Datenquellen</a></li>
                        <li><a href="/wissen/" class="hover:text-white transition">Wissen</a></li>
                        <li><a href="/quiz.html" class="hover:text-white transition">Risikocheck-Quiz</a></li>
                        <li><a href="/muster-bericht.html" class="hover:text-white transition">Muster-Bericht</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-semibold text-white text-sm mb-4">Rechtliches</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/impressum.html" class="hover:text-white transition">Impressum</a></li>
                        <li><a href="/datenschutz.html" class="hover:text-white transition">Datenschutz</a></li>
                        <li><a href="#" onclick="if(window.klaro){klaro.show();}return false;" class="hover:text-white transition">Datenschutz-Einstellungen</a></li>
                        <li><a href="/widerruf.html" class="hover:text-white transition">Widerrufsbelehrung</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
                <p class="text-xs">© 2026 Bodenbericht. Alle Rechte vorbehalten.</p>
                <div class="flex items-center gap-4 text-xs">
                    <span class="flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
                        SSL-verschlüsselt
                    </span>
                    <span class="flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                        DSGVO-konform
                    </span>
                </div>
            </div>
        </div>
    </footer>

</body>
</html>
