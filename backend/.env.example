APP_NAME=geoforensic-api
APP_VERSION=0.1.0
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/geoforensic
SECRET_KEY=replace-with-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# Stripe (leave empty for mock mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Customer-facing checkout flow happens on bodenbericht.de (Stefan-Sprint).
# Success-URL führt direkt zum Vollbericht-Empfangs-Hinweis, Cancel-URL
# zurück auf die Quiz-Ergebnis-Seite.
# Wichtig: .html-Suffix mit drin — FastAPI's StaticFiles serviert nur
# /danke.html, nicht /danke (kein implizites HTML-Routing).
STRIPE_CHECKOUT_SUCCESS_URL=https://bodenbericht.de/danke.html?bericht=premium
STRIPE_CHECKOUT_CANCEL_URL=https://bodenbericht.de/abbruch.html
# Bundle-Tiers (Modell B) + Country-Pricing seit 2026-05-05.
# NL = Launch-Markt mit aggressivem Anker (FunderConsult 7,95 €):
#   STRIPE_REPORT_PRICE_CENTS         = NL Basis (default name)
#   STRIPE_REPORT_KOMPLETT_PRICE_CENTS = NL Komplett
# DE/AT/CH = Standard-Markt:
#   STRIPE_REPORT_DE_PRICE_CENTS         = DE/AT/CH Basis
#   STRIPE_REPORT_DE_KOMPLETT_PRICE_CENTS = DE/AT/CH Komplett
# Country-Detection in payments._country_from_address_input (Heuristik
# auf PLZ-Format in der User-Eingabe). EARLY50 wirkt prozentual auf alle
# vier Tarife → Stripe-Coupon ist 50 % off.
STRIPE_REPORT_PRICE_CENTS=3900
STRIPE_REPORT_KOMPLETT_PRICE_CENTS=5900
STRIPE_REPORT_DE_PRICE_CENTS=4900
STRIPE_REPORT_DE_KOMPLETT_PRICE_CENTS=8900

# OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Email via Brevo SMTP relay (leave empty to skip sending)
# Get credentials from https://app.brevo.com/ -> SMTP & API -> SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Brevo hat geoforensic.de als Sender-Domain verifiziert (TXT brevo-code im
# DNS); bodenbericht.de aktuell NICHT — dessen SPF erlaubt nur Outlook und
# DMARC steht auf p=quarantine, also landen Mails von bericht@bodenbericht.de
# bei Gmail in der Quarantäne (silent drop). Bis bodenbericht.de mit DKIM-
# CNAME + spf.brevo.com im SPF authentifiziert ist, bleibt der Sender geo-
# forensic.de.
SMTP_FROM_EMAIL=bericht@geoforensic.de
SMTP_FROM_NAME=Bodenbericht

# Provenexpert review-request follow-up. Leer = abgeschaltet.
# Sobald Domenico das Provenexpert-Profil angelegt hat, hier die
# Profil-URL eintragen (Format: https://www.provenexpert.com/<slug>/).
# Die Mail wird via scripts/send_pending_review_requests.py verschickt
# (per Cron, siehe TEAM_HANDBOOK §4.4) für jeden Report ≥ N Tage alt.
PROVENEXPERT_REVIEW_URL=
REVIEW_REQUEST_DELAY_DAYS=7

# Public URL for download links in emails
PUBLIC_BASE_URL=https://geoforensic.de

# Admin Dashboard Token (leer lassen = kein Auth / Dev-Modus)
ADMIN_TOKEN=

# Soil raster data directory (SoilGrids, LUCAS, CORINE GeoTIFFs)
#
# This path is read by the Python backend at runtime, so it must be a path
# that exists INSIDE the container. When running via docker-compose that is
# /app/rasters (the container-side mount point). The host-side source of that
# mount is controlled separately by docker-compose's own RASTER_DIR variable
# in the repository-root .env — see DEPLOYMENT.md step 3.
#
# Only change this if you run the backend outside docker and need to point
# it at a local raster dir directly.
RASTER_DIR=/app/rasters

# Sentry Error-Tracking
#
# WICHTIG: SENTRY_DSN, SENTRY_ENVIRONMENT, SENTRY_TRACES_SAMPLE_RATE gehoeren
# NICHT in diese Datei. Sie werden von docker-compose direkt aus der
# Repo-Root-.env per ${SENTRY_DSN}-Substitution gelesen. Siehe .env.example
# im Repo-Root und docker-compose.yml Zeile ~37.
#
# Werte hier in backend/.env haetten KEINE WIRKUNG, weil das environment-
# Setting in docker-compose.yml Vorrang vor env_file hat.

# Nominatim-Cache (Redis)
#
# Nominatim ist auf 1 Request/Sekunde rate-limited. Adressen aendern sich
# praktisch nie, der Lookup wird deshalb fuer 30 Tage gecached. Wenn Redis
# nicht erreichbar ist, schaltet der Cache sich still ab und die Pipeline
# laeuft unveraendert gegen die Live-API weiter.
#
# Leer lassen = Cache aus. Unter docker-compose zeigt der Wert auf den
# Redis-Service; fuer lokales Dev ohne Docker: redis://localhost:6379/0
# EGMS L2b Calibrated API-Token fuer on-demand Time-Series-Fetch.
# Beantragt via Mail an clms-helpdesk@eea.europa.eu (siehe
# docs/MAIL_COPERNICUS_API_TOKEN.md). Wenn leer: egms_search/-burst_loader
# sind deaktiviert und Vollbericht-Bewegungsverlauf bleibt 'wird
# nachgeliefert' (Caption ist ehrlich, kein Visual-Bug).
#
# Cookie-basierte Auth wird BEWUSST nicht implementiert — siehe
# egms_search.py-Header fuer die Begruendung (ToS + Maintenance-Risiko).
EGMS_API_TOKEN=
EGMS_BASE_URL=https://egms.land.copernicus.eu

REDIS_URL=redis://redis:6379/0
# 7 Tage (vorher 30 d). OSM-Vandalismus (echter Vorfall 2026-05-05:
# "Berlin" wurde zu "Nazi-Stadt" geändert für Alexanderplatz) bleibt
# sonst zu lange in unserem Cache. Plus Vandalism-Guard in
# routers/reports.py (_contains_vandalism).
GEOCODE_CACHE_TTL_SECONDS=604800
