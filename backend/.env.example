APP_NAME=geoforensic-api
APP_VERSION=0.1.0
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/geoforensic
SECRET_KEY=replace-with-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# Stripe (leave empty for mock mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/dashboard?paid=1
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/dashboard?paid=0
STRIPE_REPORT_PRICE_CENTS=4900

# OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Email via Brevo SMTP relay (leave empty to skip sending)
# Get credentials from https://app.brevo.com/ -> SMTP & API -> SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=bericht@geoforensic.de
SMTP_FROM_NAME=Bodenbericht

# Public URL for download links in emails
PUBLIC_BASE_URL=https://geoforensic.de

# Admin Dashboard Token (leer lassen = kein Auth / Dev-Modus)
ADMIN_TOKEN=

# Soil raster data directory (SoilGrids, LUCAS, CORINE GeoTIFFs)
#
# This path is read by the Python backend at runtime, so it must be a path
# that exists INSIDE the container. When running via docker-compose that is
# /app/rasters (the container-side mount point). The host-side source of that
# mount is controlled separately by docker-compose's own RASTER_DIR variable
# in the repository-root .env — see DEPLOYMENT.md step 3.
#
# Only change this if you run the backend outside docker and need to point
# it at a local raster dir directly.
RASTER_DIR=/app/rasters

# Sentry Error-Tracking (leer = Sentry-SDK ist no-op, keine Errors gesendet)
#
# Account-Einrichtung:
#   1. Account auf sentry.io anlegen (Free-Tier reicht: 5k Events/Monat)
#   2. Beim Signup EU-Region waehlen (Server in Frankfurt, DSGVO-konform)
#   3. Neues Projekt anlegen -> Platform "Python / FastAPI"
#   4. Settings -> Client Keys (DSN) -> den DSN-String kopieren
#
# Wichtig: der DSN muss "ingest.de.sentry.io" enthalten (EU-Region).
# Wenn dort "ingest.sentry.io" (ohne de) steht, wurde US-Region gewaehlt —
# dann Projekt neu anlegen, US-DSN nicht nutzen (Daten liegen in den USA).
#
# Nach dem ersten Deploy mit gesetztem DSN den Endpoint
# POST /api/_admin/sentry-test (mit X-Admin-Token Header) einmal aufrufen.
# Ein RuntimeError landet in Sentry; wenn dort die Mailadresse als
# [email]@example.test erscheint, ist auch der PII-Scrubber aktiv.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Nominatim-Cache (Redis)
#
# Nominatim ist auf 1 Request/Sekunde rate-limited. Adressen aendern sich
# praktisch nie, der Lookup wird deshalb fuer 30 Tage gecached. Wenn Redis
# nicht erreichbar ist, schaltet der Cache sich still ab und die Pipeline
# laeuft unveraendert gegen die Live-API weiter.
#
# Leer lassen = Cache aus. Unter docker-compose zeigt der Wert auf den
# Redis-Service; fuer lokales Dev ohne Docker: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0
GEOCODE_CACHE_TTL_SECONDS=2592000
