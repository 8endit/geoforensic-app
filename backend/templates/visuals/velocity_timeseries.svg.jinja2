{#-
  Komponente 3 — Velocity-Zeitreihe + Niederschlag.
  Quelle: docs/visuals/reference_svgs/03_velocity_timeseries.svg
  Spec:   SPEC_VISUALS.md §4.3
  Daten:  data_contract.json :: components.velocity_timeseries

  Erwartet als Render-Kontext:
    chart - dict aus chart_helpers.build_timeseries_render_context()
    data  - die rohe Komponente
-#}
<svg xmlns="http://www.w3.org/2000/svg"
     width="680" height="320" viewBox="0 0 680 320"
     font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif">
  <title>GeoForensic Velocity-Zeitreihe mit Niederschlag</title>
  <desc>Bewegungsverlauf mit Trendlinie</desc>

  {% if not chart.available %}
  <text x="40" y="35" font-size="14" font-weight="500" fill="#2C2C2A">Bewegungsverlauf</text>
  <text x="40" y="53" font-size="12" fill="#5F5E5A">Zeitreihen-Datensatz wird nachgeliefert</text>
  <rect x="80" y="80" width="560" height="160" rx="8"
        fill="#F1EFE8" stroke="#888780" stroke-width="0.5"/>
  <text x="360" y="148" text-anchor="middle" font-size="13"
        fill="#5F5E5A">Quartalsweiser Bewegungsverlauf 2019–2023</text>
  <text x="360" y="170" text-anchor="middle" font-size="11"
        fill="#888780">EGMS-Zeitreihen-Import läuft. Die Velocity-Schnitte oben</text>
  <text x="360" y="186" text-anchor="middle" font-size="11"
        fill="#888780">basieren auf den Mittelwerten der Punkte und sind belastbar.</text>
  {% else %}
  <text x="40" y="35" font-size="14" font-weight="500" fill="#2C2C2A">Bewegungsverlauf · {{ chart.start_date|truncate(4, true, '') }} bis {{ chart.end_date|truncate(4, true, '') }}</text>
  <text x="40" y="53" font-size="12" fill="#5F5E5A">Negative Werte = Setzung · Säulen = monatlicher Niederschlag</text>

  {# Achsen #}
  <line x1="{{ chart.chart_x }}" y1="{{ chart.chart_y }}"
        x2="{{ chart.chart_x }}" y2="{{ chart.chart_y + chart.chart_height }}"
        stroke="#888780" stroke-width="0.5"/>
  <line x1="{{ chart.chart_x }}" y1="{{ chart.chart_y + chart.chart_height }}"
        x2="{{ chart.chart_x + chart.chart_width }}" y2="{{ chart.chart_y + chart.chart_height }}"
        stroke="#888780" stroke-width="0.5"/>

  {# Y-Achsen-Labels #}
  {% for tick in chart.y_ticks %}
  <text x="{{ chart.chart_x - 6 }}" y="{{ '%.1f' % (tick.y_px + 4) }}"
        text-anchor="end" font-size="12" fill="#5F5E5A">
    {%- if tick.value > 0 -%}+{{ '%g' % tick.value }}
    {%- elif tick.value < 0 -%}−{{ '%g' % (-tick.value) }}
    {%- else -%}0
    {%- endif -%}
  </text>
  {% endfor %}
  <text x="40" y="{{ chart.chart_y + chart.chart_height // 2 }}"
        text-anchor="middle" font-size="12" fill="#5F5E5A">mm</text>

  {# Null-Linie #}
  <line x1="{{ chart.chart_x }}" y1="{{ '%.1f' % chart.y_zero_px }}"
        x2="{{ chart.chart_x + chart.chart_width }}" y2="{{ '%.1f' % chart.y_zero_px }}"
        stroke="#B4B2A9" stroke-width="0.5" stroke-dasharray="2 3"/>

  {# Niederschlagssäulen (Hintergrund) #}
  {% for bar in chart.rain_bars %}
  <rect x="{{ '%.1f' % bar.x_px }}" y="{{ '%.1f' % bar.y_px }}"
        width="{{ '%.1f' % bar.w }}" height="{{ '%.1f' % bar.h }}"
        fill="{{ tokens.structural.precipitation.color }}" opacity="0.6"/>
  {% endfor %}

  {# PSI-Linie #}
  <path d="{{ chart.psi_path }}"
        fill="none" stroke="{{ tokens.accent.psi_motion.color }}" stroke-width="2"/>

  {# Datenpunkte #}
  {% for p in chart.psi_pts %}
  <circle cx="{{ '%.1f' % p.x_px }}" cy="{{ '%.1f' % p.y_px }}"
          r="3" fill="{{ tokens.accent.psi_motion.color }}"/>
  {% endfor %}

  {# Trendlinie #}
  {% if chart.trend %}
  <line x1="{{ '%.1f' % chart.trend.x1 }}" y1="{{ '%.1f' % chart.trend.y1 }}"
        x2="{{ '%.1f' % chart.trend.x2 }}" y2="{{ '%.1f' % chart.trend.y2 }}"
        stroke="{{ tokens.accent.trend_line.color }}" stroke-width="1"
        stroke-dasharray="4 3"/>
  <text x="{{ chart.chart_x + chart.chart_width - 5 }}"
        y="{{ '%.1f' % (chart.trend.y2 + 14) }}"
        text-anchor="end" font-size="12"
        fill="{{ tokens.accent.trend_line.color }}">
    Trend {{ fmt_signed(chart.trend.slope_mm_per_year, 1) }} mm/J
  </text>
  {% endif %}

  {# X-Achsen-Labels (Jahre) #}
  {% for tick in chart.x_year_ticks %}
  <text x="{{ '%.1f' % tick.x_px }}" y="{{ chart.chart_y + chart.chart_height + 18 }}"
        text-anchor="middle" font-size="12" fill="#5F5E5A">{{ tick.label }}</text>
  {% endfor %}

  {# Legende #}
  <rect x="80" y="280" width="12" height="10" fill="{{ tokens.accent.psi_motion.color }}"/>
  <text x="98" y="289" font-size="12" fill="#5F5E5A">Setzung (PSI-Mittel)</text>
  <rect x="220" y="280" width="12" height="10"
        fill="{{ tokens.structural.precipitation.color }}" opacity="0.6"/>
  <text x="238" y="289" font-size="12" fill="#5F5E5A">Niederschlag (DWD)</text>
  {% if chart.trend %}
  <line x1="370" y1="285" x2="390" y2="285"
        stroke="{{ tokens.accent.trend_line.color }}" stroke-width="1"
        stroke-dasharray="4 3"/>
  <text x="395" y="289" font-size="12"
        fill="{{ tokens.accent.trend_line.color }}">Trendlinie</text>
  {% endif %}

  {# Korrelations-r im Footer (Spec §4.3) #}
  {% if chart.correlation_r is not none %}
  <text x="640" y="289" text-anchor="end" font-size="12" fill="#5F5E5A">
    Pearson r = {{ '%.2f' % chart.correlation_r }} (detrendet)
  </text>
  {% endif %}
  {% endif %}
</svg>
