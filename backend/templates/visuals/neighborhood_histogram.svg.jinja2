{#-
  Komponente 6 — Nachbarschafts-Vergleich.
  Quelle: docs/visuals/reference_svgs/06_neighborhood_histogram.svg
  Spec:   SPEC_VISUALS.md §4.6
  Daten:  data_contract.json :: components.neighborhood_histogram

  Erwartet als Render-Kontext:
    hist - dict aus chart_helpers.build_histogram_render_context()
    data - die rohe Komponente
-#}
{%- set sparse = (hist.psi_count or 0) < 20 -%}
<svg xmlns="http://www.w3.org/2000/svg"
     width="680" height="280" viewBox="0 0 680 280"
     font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif">
  <title>GeoForensic Nachbarschafts-Vergleich</title>
  {#- Radius spiegelt den config.egms_radius_m wider; bei Default-Bump in
      backend/app/config.py muss dieser String mitwandern. Hardcoded weil
      hist-Render-Kontext den Wert (noch) nicht durchreicht. -#}
  <desc>Velocity-Verteilung im 750 m-Radius
    {%- if hist.own_velocity is not none %} · Adresse {{ fmt_signed(hist.own_velocity, 1) }} mm/J{% endif -%}
  </desc>

  <text x="40" y="35" font-size="14" font-weight="500" fill="#2C2C2A">Wo steht Ihr Grundstück in der Umgebung?</text>
  <text x="40" y="53" font-size="12" fill="#5F5E5A">Velocity-Verteilung aller PSI-Punkte im 750 m-Radius</text>

  {% if not hist.available %}
  <rect x="60" y="80" width="580" height="140" rx="8"
        fill="#F1EFE8" stroke="#888780" stroke-width="0.5"/>
  <text x="350" y="160" text-anchor="middle" font-size="14"
        fill="#5F5E5A">Keine Verteilung verfügbar — keine PSI-Punkte im Radius</text>
  {% else %}
  {# X-Achse #}
  <line x1="{{ hist.chart_x }}"
        y1="{{ hist.chart_y_top + hist.chart_height }}"
        x2="{{ hist.chart_x + hist.chart_width }}"
        y2="{{ hist.chart_y_top + hist.chart_height }}"
        stroke="#888780" stroke-width="0.5"/>

  {# Histogramm-Säulen #}
  {% for bar in hist.bars %}
  <rect x="{{ '%.1f' % bar.x }}" y="{{ '%.1f' % bar.y }}"
        width="{{ '%.1f' % bar.w }}" height="{{ '%.1f' % bar.h }}"
        fill="{{ bar.fill }}"/>
  {% endfor %}

  {# Marker für eigenes Grundstück #}
  {% if hist.own_x is not none %}
  <line x1="{{ '%.1f' % hist.own_x }}" y1="{{ hist.chart_y_top }}"
        x2="{{ '%.1f' % hist.own_x }}" y2="{{ hist.chart_y_top + hist.chart_height + 5 }}"
        stroke="{{ tokens.accent.own_property.color }}" stroke-width="2"
        stroke-dasharray="4 3"/>
  {%- set tag_w = 125 %}
  <rect x="{{ '%.1f' % (hist.own_x - tag_w / 2) }}" y="65"
        width="{{ tag_w }}" height="22" rx="4"
        fill="{{ tokens.accent.own_property.color }}"/>
  <text x="{{ '%.1f' % hist.own_x }}" y="80"
        text-anchor="middle" font-size="14" font-weight="500" fill="#FFFFFF">
    Ihr Grundstück
  </text>
  {% endif %}

  {# X-Achsen-Labels #}
  {% for tick in hist.x_ticks %}
  <text x="{{ '%.1f' % tick.x }}"
        y="{{ hist.chart_y_top + hist.chart_height + 20 }}"
        text-anchor="middle" font-size="12" fill="#5F5E5A">{{ tick.label }}</text>
  {% endfor %}
  {% if hist.own_x is not none %}
  <text x="{{ '%.1f' % hist.own_x }}"
        y="{{ hist.chart_y_top + hist.chart_height + 20 }}"
        text-anchor="middle" font-size="12" font-weight="500"
        fill="{{ tokens.accent.own_property.color }}">
    {{ fmt_signed(hist.own_velocity, 1) }}
  </text>
  {% endif %}

  {# Sparse-Hinweis (Spec §4.6) #}
  {% if sparse %}
  <text x="40" y="245" font-size="11" fill="#A32D2D">
    Stichprobe klein: nur {{ hist.psi_count }} PSI-Punkte im Radius — Verteilung weniger aussagekräftig.
  </text>
  {% endif %}

  {# Footer #}
  <text x="350" y="262" text-anchor="middle" font-size="12" fill="#5F5E5A">
    Velocity in mm/Jahr · {{ hist.psi_count }} PSI-Punkte ausgewertet
  </text>
  <text x="350" y="278" text-anchor="middle" font-size="12" fill="#5F5E5A">
    {{ hist.interpretation }}
  </text>
  {% endif %}
</svg>
