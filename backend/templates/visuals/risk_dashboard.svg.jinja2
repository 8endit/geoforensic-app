{#-
  Komponente 1 — Risiko-Dashboard.
  Quelle: docs/visuals/reference_svgs/01_risk_dashboard.svg
  Spec:   SPEC_VISUALS.md §4.1
  Daten:  data_contract.json :: components.risk_dashboard

  Layout (680 × 260 ViewBox):
    - Linker Block (180 × 220): Burland-Klasse als 64 px-Zahl
    - Mittlerer Stack (4 × Box ~50 px): Velocity, Trend, Datenqualität, PSI-Punkte
    - Rechter Block (210 × 220): A–E-Note als gefüllter Kreis

  Farben:
    - Burland-Box: getintete Variante der Ampel-Bandfarbe (class-driven)
    - Grade-Kreis: Ampel-Band passend zu A–E
    - Detailboxen: neutral (Spec §3 strukturelle Farben)
-#}
{%- set band = ampel_for_label(data.burland_label) -%}
{%- set grade_b = grade_band(data.overall_grade) -%}
{%- set grade_text = data.overall_grade if data.overall_grade and data.overall_grade != "—" else "—" -%}
<svg xmlns="http://www.w3.org/2000/svg"
     width="680" height="260" viewBox="0 0 680 260"
     font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif">
  <title>Bodenbericht Risiko-Dashboard</title>
  <desc>Burland-Klasse {{ data.burland_class }} ({{ data.burland_label }}),
        Gesamtbewertung {{ grade_text }}.</desc>

  {# ─── Linker Block: Burland-Klasse ──────────────────────────────────── #}
  <rect x="20" y="20" width="180" height="220" rx="12"
        fill="{{ band.color }}" fill-opacity="0.12"
        stroke="{{ band.color }}" stroke-width="0.75"/>
  {# Header in neutralem Grau für Kontrast — die Bandfarbe bleibt der
     Klassen-Zahl + Klassen-Label vorbehalten. #}
  <text x="110" y="48" text-anchor="middle" font-size="11" font-weight="600"
        fill="#5F5E5A" letter-spacing="0.04em">BURLAND-KLASSE</text>
  {# Burland-Stack: Klasse-Zahl, Label, Range. Berechnete Abstaende:
     Box ist y=20-240, Header y=48 (oben). Klasse-Zahl 64pt baseline y=130
     → optisch zentriert in der Box (mid-height ~130). Label 14pt y=170
     (40px Luft nach Klasse-baseline). Range 11pt y=198 (28px nach Label).
     Vorher (Domenico-Feedback): 33/20px asymmetrisch + zerquetscht. #}
  <text x="110" y="130" text-anchor="middle" font-size="64" font-weight="500"
        fill="{{ band.color }}">{{ data.burland_class }}</text>
  <text x="110" y="170" text-anchor="middle" font-size="14" font-weight="500"
        fill="{{ band.color }}">{{ data.burland_label }}</text>
  {%- set desc_lines = data.burland_description.split('—') if data.burland_description else [''] %}
  <text x="110" y="198" text-anchor="middle" font-size="11"
        fill="#5F5E5A">{{ desc_lines[0]|trim }}</text>

  {# ─── Mitte: 4 Detailbox-Stack ──────────────────────────────────────── #}
  {# Detail-boxes: 220 px wide, text padding 12 px on each side → ~196 px
     for the description line at font-size 11 ≈ ~32 char budget. The
     fit() helper truncates anything longer with an ellipsis so we never
     overflow the box. #}
  {# Detail-Boxen: Layout-Schema fuer ALLE drei Boxen (Bewegung/Trend/
     Datenqualitaet) gleich. Box height 50px, Header (12pt) UND Wert
     (14pt) auf der GLEICHEN baseline y_top+18. Untertitel (11pt) auf
     y_top+38. Vorher (Domenico-Feedback): Header oben links + Wert
     mittig rechts + Untertitel unten links → links Text oben+unten,
     rechts mittig = asymmetrisch zerrissen.
     Jetzt: Top-Zeile = Header links + Wert rechts (gleiche y-Linie),
     Bottom-Zeile = Untertitel allein links. Symmetrisch lesbar. #}
  {# Box 1: Bewegung #}
  <rect x="215" y="20" width="220" height="50" rx="8"
        fill="#F1EFE8" stroke="#888780" stroke-width="0.5"/>
  <text x="228" y="42" font-size="12" font-weight="500" fill="#5F5E5A">Bewegung</text>
  <text x="422" y="42" text-anchor="end" font-size="14" font-weight="500"
        fill="#2C2C2A">{{ fmt_signed(data.velocity_mm_per_year, 1) }} mm/Jahr</text>
  <text x="228" y="60" font-size="11"
        fill="#888780">{{ fit(data.velocity_basis, 32) }}</text>

  {# Box 2: Trend #}
  <rect x="215" y="80" width="220" height="50" rx="8"
        fill="#F1EFE8" stroke="#888780" stroke-width="0.5"/>
  <text x="228" y="102" font-size="12" font-weight="500" fill="#5F5E5A">Trend</text>
  <text x="422" y="102" text-anchor="end" font-size="14" font-weight="500"
        fill="#2C2C2A">{{ fit(data.trend, 18) }}</text>
  <text x="228" y="120" font-size="11"
        fill="#888780">{{ fit(data.trend_description, 32) }}</text>

  {# Box 3: Datenqualität #}
  <rect x="215" y="140" width="220" height="50" rx="8"
        fill="#F1EFE8" stroke="#888780" stroke-width="0.5"/>
  <text x="228" y="162" font-size="12" font-weight="500" fill="#5F5E5A">Datenqualität</text>
  <text x="422" y="162" text-anchor="end" font-size="14" font-weight="500"
        fill="#2C2C2A">{{ fit(data.data_quality, 12) }}</text>
  <text x="228" y="180" font-size="11"
        fill="#888780">{{ fit(data.data_quality_description, 32) }}</text>

  {# Box 4: PSI-Punkte #}
  <rect x="215" y="200" width="220" height="40" rx="8"
        fill="#F1EFE8" stroke="#888780" stroke-width="0.5"/>
  {#- Radius matches config.egms_radius_m default (500 m); hardcoded label,
      mit-aktualisieren wenn config gebumpt wird. -#}
  <text x="228" y="218" font-size="12" fill="#5F5E5A">PSI-Punkte im 500 m-Radius</text>
  <text x="422" y="230" text-anchor="end" font-size="14" font-weight="500"
        fill="#2C2C2A">{{ fmt_int(data.psi_count_in_radius) }}</text>

  {# ─── Rechter Block: A-E Gesamtbewertung ────────────────────────────── #}
  <rect x="450" y="20" width="210" height="220" rx="12"
        fill="{{ grade_b.color }}" fill-opacity="0.10"
        stroke="{{ grade_b.color }}" stroke-width="0.75"/>
  <text x="555" y="48" text-anchor="middle" font-size="11" font-weight="600"
        fill="#5F5E5A" letter-spacing="0.04em">GESAMTBEWERTUNG</text>
  <circle cx="555" cy="130" r="52" fill="{{ grade_b.color }}"/>
  <text x="555" y="146" text-anchor="middle" font-size="52" font-weight="500"
        fill="#FFFFFF">{{ grade_text }}</text>
  <text x="555" y="205" text-anchor="middle" font-size="14" font-weight="500"
        fill="{{ grade_b.color }}">{{ fit(data.overall_grade_label, 22) }}</text>
  <text x="555" y="223" text-anchor="middle" font-size="11"
        fill="#5F5E5A">{{ fit(data.overall_grade_recommendation, 32) }}</text>
</svg>
